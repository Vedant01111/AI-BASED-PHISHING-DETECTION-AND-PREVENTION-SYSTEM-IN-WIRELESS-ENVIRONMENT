# Copy this file to `.env` and fill in real values.
# `.env` itself is gitignored and must never be committed.

# Generate a fresh one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me

# Never set to True in production
DEBUG=True

# Comma-separated list, e.g. yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=127.0.0.1,localhost

# RapidAPI keys used by email_phishing/views.py (MailCheck) and
# web_phishing/views.py (SimilarWeb). Both scans work fine without
# these -- the app just skips the extra reputation lookup and the
# verdict is unaffected.
EMAIL_RAPIDAPI_KEY=
WEB_RAPIDAPI_KEY=
